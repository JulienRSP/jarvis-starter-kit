# .env.example — Template public des variables d'environnement
#
# Ce fichier EST commité dans git. Il sert de référence pour savoir quelles
# variables configurer. Ne jamais mettre de vraies valeurs ici.
#
# Pour démarrer : copie ce fichier en .env et remplis les valeurs réelles.
#   cp .env.example .env

# ── IA ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Productivité & bases de données ──────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Google / YouTube ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Déploiement & hébergement ─────────────────────────────────────────────────
VERCEL_TOKEN=your_vercel_token_here
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# ── Paiement ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Divers ────────────────────────────────────────────────────────────────────